# 数据库配置
# 推荐主链路：PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/building_energy
ENERGY_TABLE_NAME=energy_reports
FORCE_POSTGRESQL=true
STATS_DEBUG=true
# 如需临时回退 SQLite（不推荐生产使用）
# DATABASE_URL=sqlite:///./beims.db
# ENERGY_TABLE_NAME=energy_data
# FORCE_POSTGRESQL=false

# 主后端服务配置（统一主链路）
API_HOST=0.0.0.0
API_PORT=8001

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI配置（可选，用于智能问答）
OPENAI_API_KEY=
OPENAI_API_BASE=

# 智能助手代理配置（阶段3）
ASSISTANT_PROXY_ENABLED=true
ASSISTANT_BASE_URL=http://localhost:8082
ASSISTANT_PROXY_TIMEOUT=45
ASSISTANT_FALLBACK_LOCAL=true

# RagFlow配置（可选）
RAGFLOW_API_URL=http://localhost:9380
RAGFLOW_API_KEY=

# MCP服务器配置
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# 文件存储路径
UPLOAD_DIR=uploads
EXPORT_DIR=exports
KNOWLEDGE_BASE_DIR=knowledge_base

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0
