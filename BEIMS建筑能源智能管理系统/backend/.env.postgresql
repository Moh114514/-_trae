# 数据库配置
# PostgreSQL 配置（生产环境推荐）
DATABASE_URL=postgresql://postgres:你的密码@localhost:5432/building_energy
ENERGY_TABLE_NAME=energy_reports
FORCE_POSTGRESQL=true
STATS_DEBUG=true

# SQLite 配置（开发环境，默认使用）
# DATABASE_URL=sqlite:///./beims.db

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI配置（可选，用于智能问答）
OPENAI_API_KEY=
OPENAI_API_BASE=

# RagFlow配置（可选）
RAGFLOW_API_URL=http://localhost:9380
RAGFLOW_API_KEY=

# MCP服务器配置
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# 文件存储路径
UPLOAD_DIR=uploads
EXPORT_DIR=exports
KNOWLEDGE_BASE_DIR=knowledge_base

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0
